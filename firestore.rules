rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /waitlist/{entryId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name',
        'email',
        'company',
        'goal',
        'source',
        'status',
        'createdAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() >= 1
      && request.resource.data.name.size() <= 120
      && request.resource.data.email is string
      && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
      && request.resource.data.company is string
      && request.resource.data.company.size() >= 1
      && request.resource.data.company.size() <= 160
      && request.resource.data.goal is string
      && request.resource.data.goal.size() >= 1
      && request.resource.data.goal.size() <= 500
      && request.resource.data.source is string
      && request.resource.data.source.size() <= 80
      && request.resource.data.status == 'new'
      && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }
  }
}
